<% layout("layouts/boilerplate") %>

<div class="p-6 max-w-6xl mx-auto">

  <h2 class="text-2xl font-bold mb-6">All Orders</h2>

  <% if (orders.length === 0) { %>
    <p class="text-gray-500">No orders found.</p>
  <% } %>

  <% orders.forEach(order => { %>

    <div class="bg-white rounded-xl shadow mb-6 overflow-hidden">

      <!-- ================= HEADER ================= -->
      <div class="flex flex-wrap justify-between items-center gap-3 px-6 py-4 bg-gray-50 border-b">

        <div class="text-sm">
          <span class="font-semibold">Order ID:</span>
          <span class="text-gray-600"><%= order._id %></span>
        </div>

        <span class="px-3 py-1 rounded-full text-sm font-semibold
          <%= order.orderStatus === "Delivered" ? "bg-green-100 text-green-700" :
              order.orderStatus === "Cancelled" ? "bg-red-100 text-red-700" :
              "bg-blue-100 text-blue-700" %>">
          <%= order.orderStatus %>
        </span>

      </div>

      <!-- ================= BODY ================= -->
      <div class="p-6 grid md:grid-cols-2 gap-6">

        <!-- LEFT -->
        <div>

          <p class="mb-2">
            <b>User:</b>
            <span class="text-gray-600">
              <%= order.user?.email || "Unknown" %>
            </span>
          </p>

          <h6 class="font-bold mt-4 mb-2"> Delivery Address</h6>

          <p class="text-gray-600 leading-relaxed">
            <%= order.address.name %><br>
            <%= order.address.phone %><br>
            <%= order.address.street %>,
            <%= order.address.city %> -
            <%= order.address.pincode %>
          </p>

          <hr class="my-4">

          <p>
            <b>Payment Method:</b>
            <%= order.paymentMethod %>
          </p>

          <p>
            <b>Payment Status:</b>
            <span class="inline-block px-2 py-1 rounded text-sm
              <%= order.paymentStatus === "Paid" ? "bg-green-100 text-green-700" :
                  order.paymentStatus === "Failed" ? "bg-red-100 text-red-700" :
                  "bg-yellow-100 text-yellow-800" %>">
              <%= order.paymentStatus %>
            </span>
          </p>

          <h4 class="mt-3 font-bold text-lg">
            Total: &#8377;<%= order.totalAmount %>
          </h4>

        </div>

        <!-- RIGHT -->
        <div>

          <h6 class="font-bold mb-3"> Ordered Items</h6>

          <% order.items.forEach(item => { %>

            <div class="flex items-center gap-4 mb-4">

              <img
                src="<%= item.image || 'https://via.placeholder.com/60' %>"
                class="w-16 h-16 rounded-lg border object-cover">

              <div>
                <div class="font-semibold"><%= item.name %></div>
                <div class="text-gray-500 text-sm">
                  &#8377;<%= item.price %> × <%= item.quantity %>
                </div>
              </div>

            </div>

          <% }) %>

        </div>

      </div>

      <!-- ================= FOOTER ================= -->
      <div class="px-6 py-4 bg-gray-50 border-t">

        <% if (order.orderStatus === "Cancelled") { %>

          <div class="bg-red-100 text-red-700 p-3 rounded-lg">
             Order cancelled by customer
          </div>

        <% } else { %>

          <form
            action="/admin/orders/<%= order._id %>?_method=PUT"
            method="POST"
            class="flex flex-wrap items-center gap-3">

            <select
              name="orderStatus"
              class="border rounded-lg px-3 py-2">

              <% ["Placed","Preparing","Out for Delivery","Delivered"]
                  .forEach(status => { %>

                <option
                  value="<%= status %>"
                  <%= order.orderStatus === status ? "selected" : "" %>>
                  <%= status %>
                </option>

              <% }) %>

            </select>

          <button class="btn btn-success px-4 py-2 rounded-3 shadow-sm">
  Update Status
</button>

          </form>

        <% } %>

      </div>

    </div>

  <% }) %>

</div>
