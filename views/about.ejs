<% layout("layouts/boilerplate") %>

<!-- ================= ABOUT PAGE ================= -->

<div class="container-fluid px-0">

  <!-- ===== HERO ===== -->
  <section class="about-hero text-center text-white">
    <h1 class="fw-bold">About RestroOne</h1>
    <p class="lead mt-2">
      Fresh • Fast • Delicious
    </p>
  </section>

  <!-- ===== ABOUT CONTENT ===== -->
  <section class="container my-5">

    <div class="row justify-content-center">

      <div class="col-lg-8 text-center">

        <h3 class="fw-bold mb-3">Who We Are</h3>

        <p class="text-muted">
          RestroOne is a modern food ordering platform built to deliver
          fresh, hygienic and delicious meals directly to your doorstep.
          We focus on quality ingredients, fast delivery, and customer
          satisfaction.
        </p>

        <p class="text-muted">
          Our mission is simple — to make restaurant-quality food accessible
          to everyone with just a few clicks.
        </p>

      </div>

    </div>

  </section>

  <!-- ===== FEATURES ===== -->
  <section class="bg-light py-5">

    <div class="container">

      <div class="row text-center g-4">

        <div class="col-md-4">
          <div class="p-4 bg-white shadow-sm rounded h-100">
            <h3>Fast Delivery</h3>
            <p class="text-muted">
              Hot and fresh food delivered within 30 minutes.
            </p>
          </div>
        </div>

        <div class="col-md-4">
          <div class="p-4 bg-white shadow-sm rounded h-100">
            <h3> Quality Food</h3>
            <p class="text-muted">
              We use fresh ingredients and trusted vendors.
            </p>
          </div>
        </div>

        <div class="col-md-4">
          <div class="p-4 bg-white shadow-sm rounded h-100">
            <h3>Easy Payment</h3>
            <p class="text-muted">
              UPI, cards and cash on delivery supported.
            </p>
          </div>
        </div>

      </div>

    </div>

  </section>

  <!-- ===== STORY ===== -->
  <section class="container my-5">

    <div class="row justify-content-center">

      <div class="col-lg-9">

        <h3 class="fw-bold text-center mb-4">Our Story</h3>

        <p class="text-muted text-center">
          RestroOne was started with a passion for food and technology.
          We wanted to build a simple platform that connects hungry
          customers with great food — without complicated apps or delays.
        </p>

        <p class="text-muted text-center">
          Today, we proudly serve hundreds of customers every day,
          continuously improving our service quality and expanding
          our menu.
        </p>

      </div>

    </div>

  </section>

  <!-- ===== CTA ===== -->
  <section class="bg-warning text-center py-5">

    <h2 class="fw-bold mb-3 text-dark">
      Hungry already?
    </h2>

    <a href="/products" class="btn btn-dark btn-lg">
      Explore Menu
    </a>

  </section>

</div>
