<% layout("layouts/boilerplate") %>

<div class="container-fluid profile-page">

  <!-- HEADER -->
  <div class="profile-header">
    <div class="profile-card text-center">

      <h2 class="fw-bold mb-1"><%= user.username %></h2>
      <p class="text-muted mb-2"><%= user.email %></p>
      <p class="text-muted"> <%= user.mobile %></p>

      <span class="badge bg-dark mt-2">
        <%= user.role.toUpperCase() %>
      </span>

    </div>
  </div>

  <!-- DETAILS -->
  <div class="container profile-content">

    <div class="row g-4">

      <!-- ACCOUNT INFO -->
      <div class="col-md-6">
        <div class="profile-box">
          <h5 class="fw-bold mb-3"> Account Details</h5>

          <p><strong>Username:</strong> <%= user.username %></p>
          <p><strong>Email:</strong> <%= user.email %></p>
          <p><strong>Mobile:</strong> <%= user.mobile %></p>
          <p><strong>Role:</strong> <%= user.role %></p>
        </div>
      </div>

      <!-- ORDERS -->
      <div class="col-md-6">
        <div class="profile-box">
          <h5 class="fw-bold mb-3">Orders Summary</h5>

          <p><strong>Total Orders:</strong> <%= ordersCount %></p>
          <p><strong>Delivered:</strong> <%= deliveredOrders %></p>
          <p><strong>Pending:</strong> <%= pendingOrders %></p>

          <a href="/orders/my" class="btn btn-warning mt-3">
            View Orders
          </a>
        </div>
      </div>

    </div>

  </div>

</div>
