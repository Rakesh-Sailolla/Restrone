<% layout("layouts/boilerplate") %>

<!-- ================= LOCATION PAGE ================= -->

<div class="container-fluid px-0">

  <!-- ===== HERO ===== -->
  <section class="location-hero text-center text-white">
    <h1 class="fw-bold">Our Locations</h1>
    <p class="lead mt-2">
      Find the nearest RestroOne outlet
    </p>
  </section>

  <!-- ===== MAP SECTION ===== -->
  <section class="container my-5">

    <div class="row mb-4">
      <div class="col text-center">
        <h3 class="fw-bold"> Head Office</h3>
        <p class="text-muted">
          Hyderabad, Telangana, India
        </p>
      </div>
    </div>

    <div class="ratio ratio-16x9 rounded overflow-hidden shadow">
      <iframe
        src="https://www.google.com/maps?q=Hyderabad%20India&output=embed"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>

  </section>

  <!-- ===== BRANCHES ===== -->
  <section class="bg-light py-5">

    <div class="container">

      <div class="row text-center mb-4">
        <h3 class="fw-bold">Our Branches</h3>
      </div>

      <div class="row g-4">

        <div class="col-md-4">
          <div class="location-card">
            <h5 class="fw-bold">Hyderabad</h5>
            <p class="text-muted">
              Kukatpally, Miyapur Road
            </p>
            <p><i class="fa-solid fa-phone"></i>+91 93926 51327</p>
          </div>
        </div>

        <div class="col-md-4">
          <div class="location-card">
            <h5 class="fw-bold">Bangalore</h5>
            <p class="text-muted">
              Whitefield Main Road
            </p>
            <p> <i class="fa-solid fa-phone"></i>+91 93926 51327</p>
          </div>
        </div>

        <div class="col-md-4">
          <div class="location-card">
            <h5 class="fw-bold">Chennai</h5>
            <p class="text-muted">
              Anna Nagar East
            </p>
            <p><i class="fa-solid fa-phone"></i>+91 93926 51327</p>
          </div>
        </div>

      </div>

    </div>

  </section>

  <!-- ===== CTA ===== -->
  <section class="bg-warning text-center py-5">

    <h2 class="fw-bold text-dark mb-3">
      Visit us or order online
    </h2>

    <a href="/products" class="btn btn-dark btn-lg">
      Order Now
    </a>

  </section>

</div>
