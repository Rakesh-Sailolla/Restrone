<% layout("layouts/boilerplate") %>

<style>
@media (max-width: 768px) {
  .filter-panel {
    position: fixed;
    top: 70px;
    left: -100%;
    width: 85%;
    height: 100vh;
    background: #fff;
    z-index: 999;
    transition: 0.3s ease;
    overflow-y: auto;
    padding: 15px;
  }
  .filter-panel.open {
    left: 0;
  }
}
</style>

<body class="bg-light">

<div class="container-fluid py-4">
  <div class="row">

    <!-- ================= MOBILE FILTER BUTTON ================= -->
    <div class="d-lg-none mb-3">
      <button class="btn btn-outline-secondary w-100" onclick="toggleFilters()">
        Filters
      </button>
    </div>

    <!-- ================= FILTER PANEL ================= -->
    <aside id="filterPanel" class="col-lg-3 col-md-4 mb-4 filter-panel">
      <div class="card shadow-sm p-3 sticky-top position-relative" style="top:80px">

        <button
          class="btn-close position-absolute top-0 end-0 m-3 d-lg-none"
          onclick="toggleFilters()">
        </button>

        <h5 class="fw-bold mb-3"> Filters</h5>

        <input id="searchInput" class="form-control mb-3" placeholder="Search food...">

        <select id="categoryFilter" class="form-select mb-3">
          <option value="all">All</option>
          <option value="veg">veg</option>
          <option value="nonveg">nonveg</option>
          <option value="drinks">drinks</option>
          <option value="dessert">dessert</option>
        </select>

        <label class="fw-semibold">
          Max Price &#8377<span id="priceValue">1000</span>
        </label>

        <input
          type="range"
          id="priceFilter"
          min="0"
          max="1000"
          value="1000"
          class="form-range mb-3">

        <button class="btn btn-outline-secondary w-100" onclick="resetFilters()">
          Reset Filters
        </button>

      </div>
    </aside>

    <!-- ================= PRODUCTS ================= -->
    <main class="col-lg-9 col-md-8">

      <h3 class="fw-bold mb-4" id="menuTitle">
         Food Menu (<%= allitems.length %>)
      </h3>

      <div class="row g-4">

        <% allitems.forEach(item => { %>

          <div
            class="col-12 col-sm-6 col-md-6 col-lg-3 product-card"
            data-name="<%= item.foodname.toLowerCase() %>"
            data-category="<%= item.category %>"
            data-price="<%= item.price %>">

            <!-- CARD LINK -->
            <a
              href="/products/<%= item._id %>"
              class="text-decoration-none text-dark">

              <div class="card shadow-sm h-100">

                <img
                  src="<%= item.image %>"
                  class="card-img-top"
                  style="height:180px;object-fit:cover">

                <div class="card-body d-flex flex-column">

                  <h6 class="fw-bold mb-1">
                    <%= item.foodname %>
                  </h6>

                  <small class="text-muted mb-2 text-capitalize">
                    <%= item.category %>
                  </small>

                  <div class="mt-auto d-flex justify-content-between align-items-center">

                    <span class="fw-bold">
                      &#8377 <%= item.price %>
                    </span>

                  <button
  class="btn btn-sm rounded-pill food-btn"
  onclick="event.preventDefault(); event.stopPropagation(); addToCart(
    '<%= item._id %>',
    '<%= item.foodname %>',
    '<%= item.price %>',
    '<%= item.image %>'
  )">
  Add
</button>

                  </div>

                </div>
              </div>

            </a>
          </div>

        <% }) %>

      </div>
    </main>

  </div>
</div>

<!-- ================= FILTER JS ================= -->

<script>
const searchInput = document.getElementById("searchInput");
const categoryFilter = document.getElementById("categoryFilter");
const priceFilter = document.getElementById("priceFilter");
const priceValue = document.getElementById("priceValue");
const menuTitle = document.getElementById("menuTitle");

function applyFilters() {
  const search = searchInput.value.toLowerCase();
  const category = categoryFilter.value;
  const maxPrice = Number(priceFilter.value);

  let count = 0;

  document.querySelectorAll(".product-card").forEach(card => {
    const ok =
      card.dataset.name.includes(search) &&
      (category === "all" || card.dataset.category === category) &&
      Number(card.dataset.price) <= maxPrice;

    card.style.display = ok ? "" : "none";
    if (ok) count++;
  });

  menuTitle.innerText = `Food Menu (${count})`;
}

["input", "change"].forEach(e => {
  searchInput.addEventListener(e, applyFilters);
  categoryFilter.addEventListener(e, applyFilters);
  priceFilter.addEventListener(e, applyFilters);
});

priceFilter.addEventListener("input", () => {
  priceValue.innerText = priceFilter.value;
});

function resetFilters() {
  searchInput.value = "";
  categoryFilter.value = "all";
  priceFilter.value = 1000;
  priceValue.innerText = 1000;
  applyFilters();
}

function toggleFilters() {
  document.getElementById("filterPanel").classList.toggle("open");
}
</script>

</body>
