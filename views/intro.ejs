<% layout("layouts/boilerplate") %>

<!-- ================= CAROUSEL ================= -->
<div class="container-fluid px-0">

  <div
    id="carouselExampleFade"
    class="carousel slide carousel-fade"
    data-bs-ride="carousel"
    data-bs-interval="3500">

    <div class="carousel-inner">

      <!-- SLIDE 1 -->
      <div class="carousel-item active">
        <img
          src="https://images.unsplash.com/photo-1600891964599-f61ba0e24092"
          class="d-block w-100 carousel-img"
          alt="Food">

        <div class="carousel-caption text-start">
          <h1 class="fw-bold text-warning">Fresh & Delicious</h1>
          <p>Hot meals delivered to your door</p>
          <a href="/products" class="btn btn-warning btn-lg mt-2">
            Order Now
          </a>
        </div>
      </div>

      <!-- SLIDE 2 -->
      <div class="carousel-item">
        <img
          src="https://images.unsplash.com/photo-1540189549336-e6e99c3679fe"
          class="d-block w-100 carousel-img"
          alt="Burger">

        <div class="carousel-caption">
          <h1 class="fw-bold text-warning">Tasty Burgers</h1>
          <p>Juicy • Crispy • Yummy</p>
        </div>
      </div>

      <!-- SLIDE 3 -->
      <div class="carousel-item">
        <img
          src="https://images.unsplash.com/photo-1551218808-94e220e084d2"
          class="d-block w-100 carousel-img"
          alt="Pizza">

        <div class="carousel-caption text-end">
          <h1 class="fw-bold text-warning">Cheesy Pizza</h1>
          <p>Made with love</p>
        </div>
      </div>

    </div>

    <!-- CONTROLS -->
    <button class="carousel-control-prev" type="button"
      data-bs-target="#carouselExampleFade" data-bs-slide="prev">
      <span class="carousel-control-prev-icon"></span>
    </button>

    <button class="carousel-control-next" type="button"
      data-bs-target="#carouselExampleFade" data-bs-slide="next">
      <span class="carousel-control-next-icon"></span>
    </button>

  </div>
</div>


<div class="container my-5">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="fw-bold m-0"> Popular Dishes</h4>

    <a href="/products" class="view-all-btn">
      View All 
    </a>
  </div>

  <div id="foodSlider" class="carousel slide" data-bs-ride="carousel">

    <div class="carousel-inner">

      <% 
        const chunkSize = 4;
        for (let i = 0; i < allitems.length; i += chunkSize) {
          const chunk = allitems.slice(i, i + chunkSize);
      %>

      <div class="carousel-item <%= i === 0 ? 'active' : '' %>">

        <div class="product-track">

          <% chunk.forEach(item => { %>

            <div class="product-slide">

              <div class="food-box">

                <% if (item.stock > 20) { %>
                  <span class="badge food-badge">Bestseller</span>
                <% } %>

                <a href="/products/<%= item._id %>">
                  <img src="<%= item.image %>" class="food-img">
                </a>

                <h6><%= item.foodname %></h6>


                <p class="price">₹ <%= item.price %></p>

                <button
                  class="btn food-btn w-100"
                  onclick="addToCart(
                    '<%= item._id %>',
                    '<%= item.foodname %>',
                    '<%= item.price %>',
                    '<%= item.image %>'
                  )">
                  Add to Cart
                </button>

              </div>

            </div>

          <% }) %>

        </div>
      </div>

      <% } %>

    </div>

    <!-- arrows -->
    <button class="carousel-control-prev"
      type="button"
      data-bs-target="#foodSlider"
      data-bs-slide="prev">
      <span class="carousel-control-prev-icon slider-arrow"></span>
    </button>

    <button class="carousel-control-next"
      type="button"
      data-bs-target="#foodSlider"
      data-bs-slide="next">
      <span class="carousel-control-next-icon slider-arrow"></span>
    </button>

  </div>
</div>




<div class="container my-5">

  <div class="row text-center g-4">

    <div class="col-md-4">
      <div class="p-4 border rounded shadow-sm h-100">
        <h3> Fast Delivery</h3>
        <p class="text-muted">Get food in under 30 minutes</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="p-4 border rounded shadow-sm h-100">
        <h3>Quality Food</h3>
        <p class="text-muted">Fresh ingredients everyday</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="p-4 border rounded shadow-sm h-100">
        <h3> Easy Payment</h3>
        <p class="text-muted">UPI • Card • Cash on Delivery</p>
      </div>
    </div>

  </div>

</div>

<div class="bg-warning text-center py-5 text-dark">

  <h2 class="fw-bold mb-3">Hungry? Order now!</h2>
  <a href="/products" class="btn btn-dark btn-lg">
    View Menu
  </a>

</div>

<!-- ================= REVIEWS SECTION ================= -->
