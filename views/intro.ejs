            <i class="bi bi-star-fill"></i>
            <i class="bi bi-star-fill"></i>
            <i class="bi bi-star-fill"></i>
            <i class="bi bi-star"></i>
            <i class="bi bi-star"></i>
          </div>

          <p class="text-muted mx-auto" style="max-width: 600px;">
            Cow Ghee, it's really good. When the quality is not compromised,
            price wouldn't be an issue.
          </p>

          <p class="fw-semibold">
            — Venkateswara Rao
          </p>
        </div>

        <!-- Review 2 -->
        <div class="carousel-item">
          <div class="mb-2 text-warning fs-5">
            <i class="bi bi-star-fill"></i>
            <i class="bi bi-star-fill"></i>
            <i class="bi bi-star-fill"></i>
            <i class="bi bi-star-fill"></i>
            <i class="bi bi-star-fill"></i>
          </div>

          <p class="text-muted mx-auto" style="max-width: 600px;">
            Pure, fresh and authentic taste. Reminds me of our village food.
          </p>

          <p class="fw-semibold">
            — Suresh Kumar
          </p>
        </div>

        <!-- Review 3 -->
        <div class="carousel-item">
          <div class="mb-2 text-warning fs-5">
            <i class="bi bi-star-fill"></i>
            <i class="bi bi-star-fill"></i>
            <i class="bi bi-star-fill"></i>
            <i class="bi bi-star-fill"></i>
            <i class="bi bi-star"></i>
          </div>

          <p class="text-muted mx-auto" style="max-width: 600px;">
            Excellent quality and timely delivery. Highly recommended.
          </p>

          <p class="fw-semibold">
            — Anitha Reddy
          </p>
        </div>

      </div>

      <!-- Controls -->
      <button class="carousel-control-prev" type="button"
        data-bs-target="#reviewsCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon bg-dark rounded-circle p-2"></span>
      </button>

      <button class="carousel-control-next" type="button"
        data-bs-target="#reviewsCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon bg-dark rounded-circle p-2"></span>
      </button>

    </div>
  </div>

</section>


