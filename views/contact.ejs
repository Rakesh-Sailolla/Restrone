<% layout("layouts/boilerplate") %>

<!-- ================= CONTACT PAGE ================= -->

<div class="container-fluid px-0">

  <!-- ===== HERO ===== -->
  <section class="contact-hero text-center text-white">
    <h1 class="fw-bold">Contact Us</h1>
    <p class="lead mt-2">
      We’d love to hear from you
    </p>
  </section>

  <!-- ===== CONTACT INFO ===== -->
  <section class="container my-5">

    <div class="row g-4">

      <!-- LEFT INFO -->
      <div class="col-md-5">

        <h3 class="fw-bold mb-3">Get in Touch</h3>

        <p class="text-muted">
          Have questions, feedback, or need help with an order?
          Reach out to us anytime.
        </p>

        <ul class="list-unstyled mt-4">

          <li class="mb-3">
             <strong>Address:</strong><br>
            RestroOne, Main Road, Hyderabad, India
          </li>

          <li class="mb-3">
             <strong>Phone:</strong><br>
            +91 93926 51327
          </li>

          <li class="mb-3">
             <strong>Email:</strong><br>
            support@restroone.com
          </li>

        </ul>

      </div>

      <!-- RIGHT FORM -->
      <div class="col-md-7">

        <div class="card shadow-sm border-0 p-4 rounded-4">

          <h4 class="fw-bold mb-4">Send Message</h4>

          <form action="/contact" method="POST">

            <div class="row">

              <div class="col-md-6 mb-3">
                <label class="form-label">Name</label>
                <input
                  type="text"
                  name="name"
                  class="form-control"
                  placeholder="Your name"
                  required>
              </div>

              <div class="col-md-6 mb-3">
                <label class="form-label">Email</label>
                <input
                  type="email"
                  name="email"
                  class="form-control"
                  placeholder="Your email"
                  required>
              </div>

            </div>

            <div class="mb-3">
              <label class="form-label">Subject</label>
              <input
                type="text"
                name="subject"
                class="form-control"
                placeholder="Subject"
                required>
            </div>

            <div class="mb-4">
              <label class="form-label">Message</label>
              <textarea
                name="message"
                rows="5"
                class="form-control"
                placeholder="Write your message..."
                required></textarea>
            </div>

            <button type="submit" class="btn btn-warning px-4">
              Send Message
            </button>

          </form>

        </div>

      </div>

    </div>

  </section>

  <!-- ===== CTA ===== -->
  <section class="bg-warning text-center py-5">

    <h2 class="fw-bold mb-3 text-dark">
      Need help right now?
    </h2>

    <p class="mb-3 text-dark">
      Call us directly — we’re happy to help.
    </p>

    <a href="tel:+919392651327" class="btn btn-dark btn-lg">
    &#9742; Call Now
    </a>

  </section>

</div>
