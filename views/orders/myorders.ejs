<% layout("layouts/boilerplate") %>

<div class="container mt-4">

  <h3 class="mb-4 fw-bold">My Orders</h3>

  <% if (orders.length === 0) { %>
    <div class="alert alert-info text-center">
      You have not placed any orders yet.
    </div>
  <% } %>

  <% orders.forEach(order => { %>

    <div class="card mb-4 shadow-sm border-0">

      <!-- ================= HEADER ================= -->
      <div class="card-header d-flex justify-content-between align-items-center">

        <div>
          <strong>Order ID:</strong>
          <span class="text-muted small"><%= order._id %></span>
        </div>

        <span class="badge 
          <%= order.orderStatus === 'Delivered' ? 'bg-success' :
              order.orderStatus === 'Cancelled' ? 'bg-danger' :
              'bg-warning text-dark' %>">
          <%= order.orderStatus %>
        </span>

      </div>

      <!-- ================= BODY ================= -->
      <div class="card-body">

        <p class="mb-1">
          <strong>Total Amount:</strong>
          &#8377;<%= order.totalAmount %>
        </p>

        <p class="mb-1">
          <strong>Payment Method:</strong>
          <%= order.paymentMethod %>
        </p>

        <p class="mb-2">
          <strong>Payment Status:</strong>

          <span class="badge 
            <%= order.paymentStatus === 'Paid' ? 'bg-success' :
                order.paymentStatus === 'Refunded' ? 'bg-info' :
                order.paymentStatus === 'Refund Pending' ? 'bg-warning text-dark' :
                order.paymentStatus === 'Failed' ? 'bg-danger' :
                'bg-secondary' %>">
            <%= order.paymentStatus %>
          </span>
        </p>

        <hr>

        <!-- ================= ITEMS ================= -->
        <% order.items.forEach(item => { %>

          <div class="d-flex justify-content-between align-items-center border-bottom py-2">

            <div>
              <strong><%= item.name %></strong>
              <div class="text-muted small">
                Qty: <%= item.quantity %>
              </div>
            </div>

            <div>
               &#8377;<%= item.price %>
            </div>

          </div>

        <% }) %>

        <!-- ================= CANCELLATION ================= -->

        <% if (order.orderStatus === "Cancelled") { %>

          <div class="alert alert-danger mt-3 mb-0">
            <i class="fa-solid fa-xmark text-danger"></i> Order cancelled
            <% if (order.cancelledAt) { %>
              on <%= order.cancelledAt.toDateString() %>
            <% } %>
          </div>

        <% } else if (order.canCancel) { %>

          <form
            action="/orders/<%= order._id %>/cancel?_method=PUT"
            method="POST"
            class="mt-3"
          >
            <button
              class="btn btn-danger btn-sm"
              onclick="return confirm('Are you sure you want to cancel this order?')"
            >
              <i class="fa-solid fa-xmark text-danger"></i> Cancel Order
            </button>
          </form>

        <% } else { %>

          <div class="alert alert-secondary mt-3 mb-0">
            <i class="fa-solid fa-ban text-danger"></i> Order can no longer be cancelled

          </div>

        <% } %>

      </div>

      <!-- ================= FOOTER ================= -->
      <div class="card-footer text-muted small">
        Ordered on:
        <%= order.createdAt.toDateString() %>
      </div>

    </div>

  <% }) %>

</div>
