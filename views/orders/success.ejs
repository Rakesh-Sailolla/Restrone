<% layout("layouts/boilerplate") %>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
  <div class="card shadow-lg text-center p-5" style="max-width: 500px; width: 100%; border-radius: 15px;">

    <h1 class="text-success mb-3">&#9989;</h1>

    <h3 class="text-success fw-bold">
      Order Placed Successfully!
    </h3>

    <p class="text-muted mt-3">
      Thank you for your order. We're preparing your food 🍽️
    </p>

    <p class="mt-2">
      <small class="text-muted">
        Estimated delivery: 30-40 mins ⏱️
      </small>
    </p>

    <% if (orderId) { %>
      <p class="mt-3 fw-bold">
        Order ID: <%= orderId %>
      </p>
    <% } %>

    <div class="d-grid gap-2 mt-4">
      <a href="/products" class="btn btn-primary">
        Continue Shopping
      </a>

      <a href="/orders/my" class="btn btn-outline-dark">
        My Orders
      </a>
    </div>

  </div>
</div>