<% layout("layouts/boilerplate") %>

<div class="container my-4 my-md-5">

  <div class="row g-4 g-md-5">

    <!-- ================= IMAGE ================= -->
    <div class="col-12 col-md-5">

      <div class="border rounded p-3 text-center bg-white shadow-sm">

        <img
          src="<%= item.image || 'https://via.placeholder.com/500' %>"
          class="img-fluid rounded w-100"
          style="max-height:420px; object-fit:cover;"
          alt="<%= item.foodname %>">

      </div>

    </div>

    <!--DETAILS  -->
    <div class="col-12 col-md-7">

      <h2 class="fw-bold mb-2"><%= item.foodname %></h2>

     

      <!-- price -->
      <h3 class="text-danger fw-bold mb-3">
        ₹ <%= item.price.toLocaleString("en-IN") %>
      </h3>

      <!-- category -->
      <span class="badge bg-success text-capitalize mb-3">
        <%= item.category %>
      </span>

      <!-- description -->
      <p class="fs-6 fs-md-5 text-muted mt-3">
        <%= item.description %>
      </p>

      <!-- ================= QUANTITY ================= -->
      <div class="d-flex align-items-center gap-3 my-4">

        <button
          class="btn btn-outline-secondary px-3"
          onclick="changeProductQty(-1)">
          −
        </button>

        <input
          id="qty"
          type="text"
          value="1"
          readonly
          class="form-control text-center"
          style="width:80px">

        <button
          class="btn btn-outline-secondary px-3"
          onclick="changeProductQty(1)">
          +
        </button>

      </div>

      <!-- ================= ADD TO CART ================= -->
       <button
  class="btn btn-warning btn-lg px-5"
  onclick="addToCart(
    '<%= item._id %>',
    '<%= item.foodname %>',
    '<%= item.price %>',
    '<%= item.image %>',
    document.getElementById('qty').value
  )">
   Add to Cart
</button>

    </div>
  </div>

  <!-- ================= REVIEWS ================= -->
  <hr class="my-5">

  <div class="row">

    <div class="col-12 col-lg-8">

      <h4 class="fw-bold mb-4">Customer Reviews</h4>

      <!-- ADD REVIEW -->
      <% if (currentUser) { %>

        <form
          action="/products/<%= item._id %>/reviews"
          method="POST"
          class="mb-4">

          <div class="row g-2">

            <div class="col-4 col-md-3">
              <select name="rating" class="form-select" required>
                <option value="">Rating</option>
                <option>5</option>
                <option>4</option>
                <option>3</option>
                <option>2</option>
                <option>1</option>
              </select>
            </div>

            <div class="col-12">
              <textarea
                name="comment"
                class="form-control"
                rows="3"
                placeholder="Write your review..."
                required></textarea>
            </div>

            <div class="col-12">
              <button class="btn btn-success">
                Submit Review
              </button>
            </div>

          </div>
        </form>

      <% } else { %>

        <p>
          <a href="/login">Login</a> to write a review
        </p>

      <% } %>

      <!-- REVIEW LIST -->
      <% if (!item.reviews || item.reviews.length === 0) { %>

        <p class="text-muted">No reviews yet.</p>

      <% } else { %>

        <% item.reviews.forEach(r => { %>

          <div class="border rounded p-3 mb-3 bg-white shadow-sm">

            <div class="text-warning mb-1">
              <%= "★".repeat(r.rating) %><%= "☆".repeat(5 - r.rating) %>
            </div>

            <p class="mb-1"><%= r.comment %></p>

            <small class="text-muted">
              <%= new Date(r.createdAt).toDateString() %>
            </small>

          </div>

        <% }) %>

      <% } %>

    </div>
  </div>

</div>

<!-- ================= PRODUCT QUANTITY JS ================= -->
<script>
const qtyInput = document.getElementById("qty");

function changeProductQty(val) {
  let q = parseInt(qtyInput.value) || 1;
  q += val;
  if (q < 1) q = 1;
  qtyInput.value = q;
}
</script>
